            "andarBahar": {
                "title": "Andar Bahar",
                "subtitle": "Traditional Indian Card Game",
                "overview": {
                    "title": "Game Overview",
                    "p1": "Andar Bahar (also known as Katti) is a traditional Indian card game that has been played for centuries. The name comes from Hindi/Urdu, where 'Andar' means 'inside' and 'Bahar' means 'outside.' It's one of the simplest casino card games, requiring just pure luck.",
                    "p2": "Live Andar Bahar has become extremely popular online, especially among Indian players. The game's fast pace, simple rules, and cultural significance make it a favorite. Each round typically lasts less than a minute, providing non-stop action."
                },
                "howToPlay": {
                    "title": "How to Play",
                    "items": [
                        "Place Your Bet: Choose Andar (inside) or Bahar (outside)",
                        "Joker Card: Dealer draws one middle card (the 'Joker' or 'Game Card')",
                        "Dealing Begins: Dealer alternates placing cards on Andar and Bahar",
                        "First Position: Andar receives the first card (slight advantage)",
                        "Winning Side: First side to match the Joker's rank wins",
                        "Payouts: Winning bets are paid out immediately"
                    ]
                },
