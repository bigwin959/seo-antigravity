        "whyConnect": {
            "title": "Why We Partner with the Best",
            "items": [
                {
                    "title": "Fairness & Integrity",
                    "desc": "Top providers like Evolution and Pragmatic Play are audited by international regulators (eCOGRA, GLI). Their RNG (Random Number Generator) systems are certified fair."
