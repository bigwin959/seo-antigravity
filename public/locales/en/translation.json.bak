            "dragonTiger": {
                "title": "Dragon Tiger",
                "subtitle": "Fast-Paced Asian Card Game",
                "overview": {
                    "title": "Game Overview",
                    "p1": "Dragon Tiger is one of the simplest and fastest casino card games, originating from Cambodia and extremely popular throughout Asia. Often described as a two-card version of baccarat, the game strips away all complexity - it's simply about which side gets the higher card.",
                    "p2": "The game's speed and simplicity make it perfect for quick sessions and beginners. Each round takes only seconds, with no complex rules or strategies to learn. Despite its simplicity, the game offers exciting action and various side betting options."
                },
                "howToPlay": {
                    "title": "How to Play",
                    "items": [
                        "Place Your Bet: Choose Dragon, Tiger, or Tie before cards are dealt",
                        "Cards Dealt: Dealer places one card face-up on Dragon position, one on Tiger position",
                        "Compare Values: Higher card wins (Ace = 1, King = 13)",
                        "Payouts: Winning side pays 1:1, Tie pays 8:1 or 11:1",
                        "Next Round: New round begins immediately"
                    ]
                },
