            "subtitle": "এই দায়িত্বশীল গেমিং নির্দেশিকা অনুসরণ করে নিরাপদে লাইভ ডিলার গেম উপভোগ করুন",
            "dos": {
                "title": "গেমিং নির্দেশনা (Do's):",
                "items": [
                    "একটি নির্দিষ্ট বাজেট ঠিক করুন",
                    "খেলার সময়ের রেকর্ড রাখুন",
                    "বাজি ধরার আগে নিয়ম বুঝুন",
                    "ডিলারদের সম্মান করুন",
                    "জুয়াকে শুধু বিনোদন হিসেবে দেখুন"
                ]
            },
            "donts": {
                "title": "সতর্কতা (Don'ts):",
                "items": [
                    "কখনও হারানো অর্থ উদ্ধারের চেষ্টা করবেন না",
                    "ধার করা অর্থ দিয়ে খেলবেন না",
                    "আবেগপ্রবণ অবস্থায় খেলবেন না",
                    "সময়ের সীমা অবহেলা করবেন না",
                    "উচ্চ ঝুঁকিপূর্ণ বেটিং সিস্টেম এড়িয়ে চলুন"
                ]
            },
            "help": "আপনি বা আপনার পরিচিত কেউ যদি জুয়ায় আসক্ত হন, তবে অবিলম্বে পেশাদার সাহায্য নিন। দায়িত্বশীল গেমিংই নিরাপদ বিনোদনের চাবিকাঠি।"
        }
    }
}