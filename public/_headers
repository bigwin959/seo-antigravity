#Security Headers for BIGWIN959 Guide

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self' https://*.salesmartly.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://esm.sh https://cdn.tailwindcss.com https://*.salesmartly.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://*.salesmartly.com; img-src 'self' data: blob: https: http:; font-src 'self' data: https://*.salesmartly.com; connect-src 'self' https: blob: https://*.salesmartly.com https://www.google-analytics.com https://www.googletagmanager.com; media-src 'self' blob: https://*.salesmartly.com; frame-src 'self' blob: https://*.salesmartly.com; frame-ancestors 'self';
  Cache-Control: public, max-age=0, must-revalidate

#Cache static assets

/assets/*
  Cache-Control: public, max-age=31536000, immutable

#Cache images

/images/*
  Cache-Control: public, max-age=31536000, immutable

#Cache fonts

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

#Sitemap and Robots

/sitemap.xml
  Content-Type: application/xml
  Cache-Control: public, max-age=86400

/robots.txt
  Content-Type: text/plain
  Cache-Control: public, max-age=86400
